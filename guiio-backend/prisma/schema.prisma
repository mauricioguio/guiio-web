generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String
  price       Float
  collection  String
  type        ProductType @default(CONJUNTO)
  gender      String
  featured    Boolean     @default(false)
  inStock     Boolean     @default(true)
  active      Boolean     @default(true)
  tags        String[]
  images      String[]
  topSizes    String[]
  bottomSizes String[]
  colors      Json
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  collectionLinks CollectionProduct[]
}

model Collection {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  image       String?
  featured    Boolean  @default(false)
  active      Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  productLinks CollectionProduct[]
}

model CollectionProduct {
  productId    String
  collectionId String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([productId, collectionId])
}

model Sede {
  id        String      @id @default(cuid())
  name      String
  empresa   String      @default("GUIIO")
  pin       String?
  active    Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  inventory     Inventory[]
  sales         Sale[]
  productPrices SedeProductPrice[]

  @@unique([name, empresa])
}

model SedeProductPrice {
  id        String @id @default(cuid())
  sedeId    String
  productId String
  price     Float
  sede      Sede   @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  @@unique([sedeId, productId])
}

model Sale {
  id            String     @id @default(cuid())
  orderNumber   Int        @default(autoincrement())
  sedeId        String
  type          SaleType   @default(STOCK)
  status        SaleStatus @default(COMPLETED)
  total         Float
  customerName   String?
  customerPhone  String?
  notes          String?
  deliveryDate   DateTime?
  paymentMethod  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  sede         Sede              @relation(fields: [sedeId], references: [id])
  items        SaleItem[]
  payments     SalePayment[]
  editRequests SaleEditRequest[]
}

model SaleItem {
  id           String  @id @default(cuid())
  saleId       String
  productId    String
  productName  String
  size         String
  quantity     Int
  price        Float
  note         String?
  deliveredQty Int     @default(0)

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model SalePayment {
  id        String   @id @default(cuid())
  saleId    String
  amount    Float
  note      String?
  createdAt DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

enum SaleType {
  STOCK
  FABRICAR
}

enum SaleStatus {
  COMPLETED
  PENDING
  PRODUCING
  READY
  IN_STORE
  DELIVERED
  CANCELLED
}

model Inventory {
  id        String   @id @default(cuid())
  sedeId    String
  productId String
  size      String
  quantity  Int      @default(0)
  updatedAt DateTime @updatedAt
  sede      Sede     @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  @@unique([sedeId, productId, size])
}

model SellerCustomer {
  phone     String   @id
  empresa   String   @default("GUIIO")
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String
  cedula    String?
  createdAt DateTime @default(now())

  orders Order[]
}

model Order {
  id         String      @id @default(cuid())
  reference  String      @unique
  status     OrderStatus @default(PENDING)
  total      Float
  shipping   Float
  discount   Float       @default(0)
  address    String
  city       String
  notes      String?
  wompiTxId       String?
  paymentProvider String?  @default("wompi")
  createdAt       DateTime @default(now())
  updatedAt  DateTime    @updatedAt

  customerId   String
  customer     Customer           @relation(fields: [customerId], references: [id])
  items        OrderItem[]
  editRequests OrderEditRequest[]
}

model OrderItem {
  id          String @id @default(cuid())
  quantity    Int
  price       Float
  productName String
  topSize     String
  bottomSize  String
  color       String

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])
}

model SaleEditRequest {
  id          String            @id @default(cuid())
  saleId      String
  sale        Sale              @relation(fields: [saleId], references: [id])
  status      EditRequestStatus @default(PENDING)
  requestedBy String
  reason      String?
  changes     Json
  reviewNote  String?
  reviewedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model OrderEditRequest {
  id          String            @id @default(cuid())
  orderId     String
  order       Order             @relation(fields: [orderId], references: [id])
  status      EditRequestStatus @default(PENDING)
  requestedBy String
  reason      String?
  changes     Json
  reviewNote  String?
  reviewedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

enum EditRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductType {
  CONJUNTO
  TOP
  BOTTOM
  OTRO
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

model FunnelEvent {
  id          String   @id @default(cuid())
  event       String
  productId   String?
  productName String?
  price       Float?
  quantity    Int?
  createdAt   DateTime @default(now())

  @@index([event, createdAt])
}

model HeroSettings {
  id                    String   @id @default("singleton")
  backgroundImage       String?
  backgroundImageMobile String?
  imagePosition         String?
  badge           String?
  title           String?
  subtitle        String?
  buttons         Json     @default("[]")
  updatedAt       DateTime @updatedAt
}

model HomeSections {
  id            String   @id @default("singleton")
  storyText     String?
  storyImage    String?
  galleryImages Json     @default("[]")
  updatedAt     DateTime @updatedAt
}

model AbandonedCart {
  id            String    @id @default(cuid())
  reference     String    @unique
  customerName  String
  customerEmail String
  customerPhone String
  city          String?
  items         Json
  total         Float
  createdAt     DateTime  @default(now())
  convertedAt   DateTime?

  @@index([createdAt])
  @@index([convertedAt])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  source    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([source, createdAt])
}
